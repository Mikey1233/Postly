PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Authentication
# Password is set on first run via the /signup page — no env var needed.
# SESSION_DURATION_HOURS controls how long a login session lasts (default 12h).
SESSION_DURATION_HOURS=12

# Your server's public URL — used to auto-generate OAuth redirect URIs shown in the UI.
# Development: http://localhost:3001
# Production:  https://postly-pusg.onrender.com
SERVER_URL=https://postly-pusg.onrender.com

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Token encryption — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Platform app credentials (LinkedIn, Facebook, X, Reddit) are no longer stored here.
# Add them directly from the Platforms page in the app — they are saved encrypted in Supabase.
