PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Your server's public URL — used to auto-generate OAuth redirect URIs shown in the UI.
# Development: http://localhost:3001
# Production:  your Railway/Render URL (e.g. https://postly-server.up.railway.app)
SERVER_URL=http://localhost:3001

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Token encryption — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Platform app credentials (LinkedIn, Facebook, X, Reddit) are no longer stored here.
# Add them directly from the Platforms page in the app — they are saved encrypted in Supabase.
